# Set DATABASE_URL so Login, Register, and Forgot Password work without a backend.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# After changing DATABASE_URL or pulling schema updates, run: python run_migration.py
# Backend API URL (only needed if not using DATABASE_URL for auth).
API_BASE=http://localhost:4000

# PayPal Sandbox (set these to enable payments)
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_paypal_sandbox_client_id
PAYPAL_CLIENT_SECRET=your_paypal_sandbox_client_secret
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id

# Streamlit app port (default in .streamlit/config.toml is 8080). Override: streamlit run main.py --server.port 8501
# SERVER_PORT=8080
